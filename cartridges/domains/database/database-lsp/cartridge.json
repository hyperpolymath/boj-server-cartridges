{
  "$schema": "https://hyperpolymath.dev/standards/cartridges/cartridge-v1.json",
  "spdx": "MPL-2.0",
  "copyright": "Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath)",
  "name": "database-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for database query languages and schemas. Provides IDE integration for SQL syntax, schema completion, query plan hints, and migration diagnostics across PostgreSQL, MySQL, SQLite, Redis, MongoDB, and Neo4j.",
  "domain": "Database",
  "category": "domain",
  "tier": "Ayo",
  "protocols": [
    "LSP"
  ],
  "states": [
    "scaffolded"
  ],
  "auth": {
    "method": "none",
    "env_var": null,
    "credential_source": null
  },
  "api": {
    "base_url": "local://database-lsp",
    "content_type": "application/vscode-jsonrpc; charset=utf-8"
  },
  "tools": [
    {
      "name": "lsp_initialize",
      "description": "LSP initialize handshake. Returns server capabilities.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rootUri": {
            "type": "string",
            "description": "Workspace root URI"
          },
          "capabilities": {
            "type": "object",
            "description": "Client LSP capabilities"
          }
        },
        "required": [
          "rootUri"
        ]
      }
    },
    {
      "name": "lsp_text_document_diagnostic",
      "description": "Run validator on a document and return diagnostics (errors, warnings, hints).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "Document URI"
          },
          "backend": {
            "type": "string",
            "enum": [
              "postgresql",
              "mysql",
              "sqlite",
              "redis",
              "mongodb",
              "neo4j"
            ],
            "description": "Backend provider"
          }
        },
        "required": [
          "uri",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_hover",
      "description": "Return documentation or type info at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "postgresql",
              "mysql",
              "sqlite",
              "redis",
              "mongodb",
              "neo4j"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_completion",
      "description": "Return completion items at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "postgresql",
              "mysql",
              "sqlite",
              "redis",
              "mongodb",
              "neo4j"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_workspace_execute_command",
      "description": "Execute a domain-specific command.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "database.lintQuery",
              "database.explainPlan",
              "database.schemaIntrospect",
              "database.migrationCheck"
            ]
          },
          "arguments": {
            "type": "array",
            "description": "Command-specific arguments"
          }
        },
        "required": [
          "command"
        ]
      }
    }
  ],
  "backends": [
    {
      "id": "postgresql",
      "binary": "psql",
      "extensions": [
        ".sql"
      ]
    },
    {
      "id": "mysql",
      "binary": "mysql",
      "extensions": [
        ".sql"
      ]
    },
    {
      "id": "sqlite",
      "binary": "sqlite3",
      "extensions": [
        ".sql",
        ".sqlite"
      ]
    },
    {
      "id": "redis",
      "binary": "redis-cli",
      "extensions": [
        ".redis"
      ]
    },
    {
      "id": "mongodb",
      "binary": "mongosh",
      "extensions": [
        ".mongo",
        ".js"
      ]
    },
    {
      "id": "neo4j",
      "binary": "cypher-shell",
      "extensions": [
        ".cypher"
      ]
    }
  ],
  "loopback": {
    "host": "127.0.0.1",
    "port": 5182
  },
  "source": {
    "registry": "hyperpolymath/boj-server-cartridges",
    "path": "cartridges/domains/database/database-lsp"
  }
}
