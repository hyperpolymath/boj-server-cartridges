{
  "$schema": "https://hyperpolymath.dev/standards/cartridges/cartridge-v1.json",
  "spdx": "MPL-2.0",
  "copyright": "Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath)",
  "name": "proof-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for proof assistants. Provides IDE integration for proof checking, goal display, tactic completion, theorem search, and hover documentation across Coq, Lean, Isabelle, and Agda.",
  "domain": "Formal Verification",
  "category": "domain",
  "tier": "Ayo",
  "protocols": [
    "LSP"
  ],
  "states": [
    "scaffolded",
    "adapter-implemented"
  ],
  "auth": {
    "method": "none",
    "env_var": null,
    "credential_source": null
  },
  "api": {
    "base_url": "local://proof-lsp",
    "content_type": "application/vscode-jsonrpc; charset=utf-8"
  },
  "tools": [
    {
      "name": "lsp_initialize",
      "description": "LSP initialize handshake. Returns server capabilities for proof assistant integration.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rootUri": {
            "type": "string",
            "description": "Workspace root URI"
          },
          "capabilities": {
            "type": "object",
            "description": "Client LSP capabilities"
          }
        },
        "required": ["rootUri"]
      }
    },
    {
      "name": "lsp_text_document_diagnostic",
      "description": "Run proof checker on a document and return diagnostics (errors, warnings, unsolved goals).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "Document URI (file:///...)"
          },
          "backend": {
            "type": "string",
            "enum": ["coq", "lean", "isabelle", "agda"],
            "description": "Proof assistant backend"
          }
        },
        "required": ["uri", "backend"]
      }
    },
    {
      "name": "lsp_text_document_hover",
      "description": "Return proof state, type information, or theorem documentation at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {"type": "string"},
          "position": {
            "type": "object",
            "properties": {
              "line": {"type": "integer"},
              "character": {"type": "integer"}
            },
            "required": ["line", "character"]
          },
          "backend": {
            "type": "string",
            "enum": ["coq", "lean", "isabelle", "agda"]
          }
        },
        "required": ["uri", "position", "backend"]
      }
    },
    {
      "name": "lsp_text_document_completion",
      "description": "Return tactic / lemma / theorem completion items at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {"type": "string"},
          "position": {
            "type": "object",
            "properties": {
              "line": {"type": "integer"},
              "character": {"type": "integer"}
            },
            "required": ["line", "character"]
          },
          "backend": {
            "type": "string",
            "enum": ["coq", "lean", "isabelle", "agda"]
          }
        },
        "required": ["uri", "position", "backend"]
      }
    },
    {
      "name": "lsp_workspace_execute_command",
      "description": "Execute a custom proof command (check_proof, show_goals, apply_tactic, search_theorem).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": ["proof.check", "proof.showGoals", "proof.applyTactic", "proof.searchTheorem"]
          },
          "arguments": {
            "type": "array",
            "description": "Command-specific arguments"
          }
        },
        "required": ["command"]
      }
    }
  ],
  "backends": [
    {
      "id": "coq",
      "binary": "coqc",
      "alt_binaries": ["coqtop"],
      "extensions": [".v"]
    },
    {
      "id": "lean",
      "binary": "lean",
      "extensions": [".lean"]
    },
    {
      "id": "isabelle",
      "binary": "isabelle",
      "extensions": [".thy"]
    },
    {
      "id": "agda",
      "binary": "agda",
      "extensions": [".agda", ".lagda"]
    }
  ],
  "loopback": {
    "host": "127.0.0.1",
    "port": 5179
  },
  "source": {
    "registry": "hyperpolymath/boj-server-cartridges",
    "path": "cartridges/domains/formal-verification/proof-lsp"
  }
}
