{
  "$schema": "https://hyperpolymath.dev/standards/cartridges/cartridge-v1.json",
  "spdx": "MPL-2.0",
  "copyright": "Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath)",
  "name": "cloud-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for cloud-provider infrastructure. Provides IDE integration for resource validation, IAM lint, region/zone completion, and cost hints across AWS, Azure, GCP, and DigitalOcean.",
  "domain": "Cloud",
  "category": "domain",
  "tier": "Ayo",
  "protocols": [
    "LSP"
  ],
  "states": [
    "scaffolded"
  ],
  "auth": {
    "method": "none",
    "env_var": null,
    "credential_source": null
  },
  "api": {
    "base_url": "local://cloud-lsp",
    "content_type": "application/vscode-jsonrpc; charset=utf-8"
  },
  "tools": [
    {
      "name": "lsp_initialize",
      "description": "LSP initialize handshake. Returns server capabilities.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rootUri": {
            "type": "string",
            "description": "Workspace root URI"
          },
          "capabilities": {
            "type": "object",
            "description": "Client LSP capabilities"
          }
        },
        "required": [
          "rootUri"
        ]
      }
    },
    {
      "name": "lsp_text_document_diagnostic",
      "description": "Run validator on a document and return diagnostics (errors, warnings, hints).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "Document URI"
          },
          "backend": {
            "type": "string",
            "enum": [
              "aws",
              "azure",
              "gcp",
              "digitalocean"
            ],
            "description": "Backend provider"
          }
        },
        "required": [
          "uri",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_hover",
      "description": "Return documentation or type info at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "aws",
              "azure",
              "gcp",
              "digitalocean"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_completion",
      "description": "Return completion items at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "aws",
              "azure",
              "gcp",
              "digitalocean"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_workspace_execute_command",
      "description": "Execute a domain-specific command.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "cloud.validate",
              "cloud.iamLint",
              "cloud.estimateCost",
              "cloud.listResources"
            ]
          },
          "arguments": {
            "type": "array",
            "description": "Command-specific arguments"
          }
        },
        "required": [
          "command"
        ]
      }
    }
  ],
  "backends": [
    {
      "id": "aws",
      "binary": "aws",
      "extensions": [
        ".tf",
        ".cfn.yaml",
        ".cfn.json"
      ]
    },
    {
      "id": "azure",
      "binary": "az",
      "extensions": [
        ".bicep"
      ]
    },
    {
      "id": "gcp",
      "binary": "gcloud",
      "extensions": [
        ".tf"
      ]
    },
    {
      "id": "digitalocean",
      "binary": "doctl",
      "extensions": [
        ".yaml"
      ]
    }
  ],
  "loopback": {
    "host": "127.0.0.1",
    "port": 5180
  },
  "source": {
    "registry": "hyperpolymath/boj-server-cartridges",
    "path": "cartridges/domains/cloud/cloud-lsp"
  }
}
