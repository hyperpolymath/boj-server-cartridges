root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{json,yml,yaml,md,adoc,a2ml,ts}]
indent_size = 2

[*.zig]
indent_size = 4

[Makefile]
indent_style = tab

[Justfile]
indent_style = tab
