{
  "$schema": "https://hyperpolymath.dev/standards/cartridges/cartridge-v1.json",
  "spdx": "MPL-2.0",
  "copyright": "Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath)",
  "name": "ssg-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for static-site-generator content and templates. Provides IDE integration for shortcode/templating completion, frontmatter validation, broken-link diagnostics, and template-syntax hints across Hugo, mdbook, Zola, Hakyll, Franklin, and casket-ssg (Jekyll replacement per estate policy).",
  "domain": "Web",
  "category": "domain",
  "tier": "Ayo",
  "protocols": [
    "LSP"
  ],
  "states": [
    "scaffolded"
  ],
  "auth": {
    "method": "none",
    "env_var": null,
    "credential_source": null
  },
  "api": {
    "base_url": "local://ssg-lsp",
    "content_type": "application/vscode-jsonrpc; charset=utf-8"
  },
  "tools": [
    {
      "name": "lsp_initialize",
      "description": "LSP initialize handshake. Returns server capabilities.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rootUri": {
            "type": "string",
            "description": "Workspace root URI"
          },
          "capabilities": {
            "type": "object",
            "description": "Client LSP capabilities"
          }
        },
        "required": [
          "rootUri"
        ]
      }
    },
    {
      "name": "lsp_text_document_diagnostic",
      "description": "Run validator on a document and return diagnostics (errors, warnings, hints).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "Document URI"
          },
          "backend": {
            "type": "string",
            "enum": [
              "hugo",
              "mdbook",
              "zola",
              "hakyll",
              "franklin",
              "casket-ssg"
            ],
            "description": "Backend provider"
          }
        },
        "required": [
          "uri",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_hover",
      "description": "Return documentation or type info at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "hugo",
              "mdbook",
              "zola",
              "hakyll",
              "franklin",
              "casket-ssg"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_text_document_completion",
      "description": "Return completion items at a position.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer"
              },
              "character": {
                "type": "integer"
              }
            },
            "required": [
              "line",
              "character"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "hugo",
              "mdbook",
              "zola",
              "hakyll",
              "franklin",
              "casket-ssg"
            ]
          }
        },
        "required": [
          "uri",
          "position",
          "backend"
        ]
      }
    },
    {
      "name": "lsp_workspace_execute_command",
      "description": "Execute a domain-specific command.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "ssg.frontmatterValidate",
              "ssg.shortcodeComplete",
              "ssg.linkCheck",
              "ssg.templateValidate"
            ]
          },
          "arguments": {
            "type": "array",
            "description": "Command-specific arguments"
          }
        },
        "required": [
          "command"
        ]
      }
    }
  ],
  "backends": [
    {
      "id": "hugo",
      "binary": "hugo",
      "extensions": [
        ".md",
        ".html",
        ".toml"
      ]
    },
    {
      "id": "mdbook",
      "binary": "mdbook",
      "extensions": [
        ".md",
        ".toml"
      ]
    },
    {
      "id": "zola",
      "binary": "zola",
      "extensions": [
        ".md",
        ".html",
        ".toml"
      ]
    },
    {
      "id": "hakyll",
      "binary": "stack",
      "extensions": [
        ".md",
        ".html"
      ]
    },
    {
      "id": "franklin",
      "binary": "julia",
      "extensions": [
        ".md",
        ".html"
      ]
    },
    {
      "id": "casket-ssg",
      "binary": "casket-ssg",
      "extensions": [
        ".md",
        ".html"
      ]
    }
  ],
  "loopback": {
    "host": "127.0.0.1",
    "port": 5189
  },
  "source": {
    "registry": "hyperpolymath/boj-server-cartridges",
    "path": "cartridges/domains/web/ssg-lsp"
  }
}
